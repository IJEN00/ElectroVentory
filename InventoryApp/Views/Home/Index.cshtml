@model InventoryApp.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Přehled";

    var hasLow = Model.LowStockCount > 0;

    var hour = DateTime.Now.Hour;
    var greeting = hour < 11 ? "Dobré ráno" : (hour < 18 ? "Dobrý den" : "Dobrý večer");
    var subGreeting = "Vítejte zpět v systému skladu.";

    int activeProjectsCount = Model.ActiveProjects?.Count ?? 0;
}

<div class="container-fluid" style="max-width: 1500px;">

    @* --- HLAVIČKA A TLAČÍTKA --- *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 gap-3">
        <div>
            <h6 class="text-uppercase text-muted small fw-bold mb-1">Přehled</h6>
            <h2 class="fw-bold mb-0">@greeting!</h2>
            <p class="text-muted mb-0">@subGreeting</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Components" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Nová součástka
            </a>
            <a asp-controller="Projects" asp-action="Create" class="btn btn-white border shadow-sm">
                <i class="bi bi-clipboard-plus me-1"></i> Nový projekt
            </a>
        </div>
    </div>

    @* --- 4 KPI KARTY (TOP PANEL) --- *@
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3 p-xl-4 d-flex align-items-center">
                    <div class="icon-shape bg-primary bg-opacity-10 text-primary rounded-4 p-3 me-3">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-0">Skladem</h6>
                        <h3 class="fw-bold mb-0">@Model.TotalComponents</h3>
                        <small class="text-muted">Celkem @Model.TotalQuantity ks</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 @(hasLow ? "border-start border-4 border-warning" : "border-start border-4 border-success")">
                <div class="card-body p-3 p-xl-4 d-flex align-items-center">
                    <div class="icon-shape @(hasLow ? "bg-warning bg-opacity-10 text-warning" : "bg-success bg-opacity-10 text-success") rounded-4 p-3 me-3">
                        <i class="bi @(hasLow ? "bi-exclamation-diamond" : "bi-check-circle") fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-0">Zásoby</h6>
                        <h3 class="fw-bold mb-0 @(hasLow ? "text-dark" : "text-success")">
                            @(hasLow? Model.LowStockCount.ToString() : "OK")
                        </h3>
                        <small class="text-muted">
                            @(hasLow ? "Položky pod limitem" : "Vše v normě")
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 border-start border-4 border-primary">
                <div class="card-body p-3 p-xl-4 d-flex align-items-center">
                    <div class="icon-shape bg-primary bg-opacity-10 text-primary rounded-4 p-3 me-3">
                        <i class="bi bi-tools fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-0">Projekty</h6>
                        <h3 class="fw-bold mb-0">@activeProjectsCount</h3>
                        <small class="text-muted">Rozpracované</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3 p-xl-4 d-flex align-items-center">
                    <div class="icon-shape bg-info bg-opacity-10 text-info rounded-4 p-3 me-3">
                        <i class="bi bi-graph-up-arrow fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-0">Aktivita</h6>
                        <h3 class="fw-bold mb-0">30 dní</h3>
                        <a asp-controller="Reports" asp-action="Consumption" class="text-decoration-none small">
                            Zobrazit report <i class="bi bi-chevron-right" style="font-size: 0.8em;"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* --- HLAVNÍ MŘÍŽKA --- *@
    <div class="row g-4">

        @* LEVÝ SLOUPEC: Graf (širší) *@
        <div class="col-lg-7 col-xl-8">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0">Trend spotřeby</h5>
                        <small class="text-muted">Nejpoužívanější součástky za posledních 30 dní</small>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (Model.ConsumptionLabels == null || !Model.ConsumptionLabels.Any())
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted py-5">
                            <i class="bi bi-bar-chart fs-1 mb-2 opacity-25"></i>
                            <p>Zatím žádná data o spotřebě.</p>
                        </div>
                    }
                    else
                    {
                        <div style="height: 100%; min-height: 350px; width: 100%;">
                            <canvas id="consumptionChart"></canvas>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* PRAVÝ SLOUPEC: Seznamy (užší) *@
        <div class="col-lg-5 col-xl-4 d-flex flex-column gap-4">

            @* 1. Kritické zásoby (Kompaktní) *@
            <div class="card border-0 shadow-sm rounded-4 flex-grow-1">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-2 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0">Kritické zásoby</h5>
                    </div>
                    @if (Model.LowStockCount > 4)
                    {
                        <a asp-controller="Reports" asp-action="LowStock" class="btn btn-sm btn-link text-decoration-none p-0">Vše (@Model.LowStockCount) <i class="bi bi-arrow-right"></i></a>
                    }
                </div>
                <div class="card-body p-0">
                    @if (Model.LowStock != null && Model.LowStock.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var c in Model.LowStock.Take(4))
                            {
                                int rp = (c.ReorderPoint ?? 5);
                                int toBuy = Math.Max(rp - c.Quantity, 0);
                                <div class="list-group-item px-4 py-3 border-light">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center overflow-hidden">
                                            <div class="rounded-circle bg-warning bg-opacity-10 text-warning p-2 me-3 flex-shrink-0 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                                <i class="bi bi-exclamation-triangle"></i>
                                            </div>
                                            <div class="text-truncate">
                                                <a asp-controller="Components" asp-action="Details" asp-route-id="@c.Id" class="text-dark text-decoration-none fw-bold d-block text-truncate" style="max-width: 180px;">@c.Name</a>
                                                <small class="text-muted">Zbývá: <span class="text-danger fw-bold">@c.Quantity</span> (Min: @rp)</small>
                                            </div>
                                        </div>
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill">+@toBuy ks</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-check-circle fs-3 text-success opacity-50 d-block mb-1"></i>
                            <small>Vše v pořádku.</small>
                        </div>
                    }
                </div>
            </div>

            @* 2. Rozpracované projekty (Kompaktní) *@
            <div class="card border-0 shadow-sm rounded-4 flex-grow-1">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-2 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0">Projekty ve výrobě</h5>
                    </div>
                    @if (activeProjectsCount > 4)
                    {
                        <a asp-controller="Projects" asp-action="Index" class="btn btn-sm btn-link text-decoration-none p-0">Vše (@activeProjectsCount) <i class="bi bi-arrow-right"></i></a>
                    }
                </div>
                <div class="card-body p-0">
                    @if (Model.ActiveProjects != null && Model.ActiveProjects.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var project in Model.ActiveProjects.Take(4))
                            {
                                string badgeClass = project.Status switch
                                {
                                    InventoryApp.Models.ProjectStatus.Planning => "bg-secondary",
                                    InventoryApp.Models.ProjectStatus.Ordered => "bg-warning text-dark",
                                    InventoryApp.Models.ProjectStatus.ReadyToBuild => "bg-info text-dark",
                                    InventoryApp.Models.ProjectStatus.InProduction => "bg-primary",
                                    _ => "bg-light text-dark border"
                                };

                                // Správný překlad do češtiny
                                string statusText = project.Status switch
                                {
                                    InventoryApp.Models.ProjectStatus.Planning => "Plánování",
                                    InventoryApp.Models.ProjectStatus.Ordered => "Objednáno",
                                    InventoryApp.Models.ProjectStatus.ReadyToBuild => "Připraveno",
                                    InventoryApp.Models.ProjectStatus.InProduction => "Ve výrobě",
                                    InventoryApp.Models.ProjectStatus.Completed => "Hotovo",
                                    _ => project.Status.ToString()
                                };

                                int totalItems = project.Items?.Count ?? 0;

                                <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id" class="list-group-item list-group-item-action px-4 py-3 border-light">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="text-dark fw-bold text-truncate me-2" style="max-width: 180px;">@project.Name</span>
                                        <div>
                                            @switch (project.Status)
                                            {
                                                case InventoryApp.Models.ProjectStatus.Planning:
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill px-2 py-1" style="font-size: 0.75em;"><i class="bi bi-lightbulb me-1"></i> Plánování</span>
                                                    break;
                                                case InventoryApp.Models.ProjectStatus.Ordered:
                                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-2 py-1" style="font-size: 0.75em;"><i class="bi bi-cart me-1"></i> Objednáno</span>
                                                    break;
                                                case InventoryApp.Models.ProjectStatus.ReadyToBuild:
                                                    <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-2 py-1" style="font-size: 0.75em;"><i class="bi bi-box-seam me-1"></i> Připraveno</span>
                                                    break;
                                                case InventoryApp.Models.ProjectStatus.InProduction:
                                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary rounded-pill px-2 py-1" style="font-size: 0.75em;"><i class="bi bi-tools me-1"></i> Ve výrobě</span>
                                                    break;
                                                case InventoryApp.Models.ProjectStatus.Completed:
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-2 py-1" style="font-size: 0.75em;"><i class="bi bi-check-circle me-1"></i> Hotovo</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-light text-dark border rounded-pill px-2 py-1" style="font-size: 0.75em;">@project.Status</span>
                                                    break;
                                            }
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> Odhad: <strong>@project.EstimatedHours h</strong></small>
                                        <small class="text-muted"><i class="bi bi-list-task me-1"></i> <strong>@totalItems</strong> položek</small>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-kanban fs-3 opacity-25 d-block mb-1"></i>
                            <small>Žádné aktivní projekty.</small>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ConsumptionLabels));
        const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ConsumptionValues));

        const shorten = (s, max = 15) => (s && s.length > max) ? (s.slice(0, max - 1) + "…") : s;

        if (labels && labels.length > 0) {
            const ctx = document.getElementById("consumptionChart");
            const barColor = 'rgba(54, 162, 235, 0.7)';
            const barBorder = 'rgba(54, 162, 235, 1)';
            new Chart(ctx, {
                type: "bar",
                data: {
                    labels: labels,
                    datasets: [{
                        label: "Spotřeba (ks)",
                        data: values,
                        backgroundColor: barColor,
                        borderColor: barBorder,
                        borderWidth: 1,
                        borderRadius: 6,
                        barThickness: 'flex',
                        maxBarThickness: 40
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(0,0,0,0.8)',
                            padding: 12,
                            titleFont: { size: 14 },
                            bodyFont: { size: 13 },
                            callbacks: {
                                title: (items) => labels[items[0].dataIndex] ?? "",
                                label: (item) => ` Spotřebováno: ${item.raw} ks`
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false, drawBorder: false },
                            ticks: {
                                font: { size: 11 },
                                callback: function (value, index) {
                                    return shorten(labels[index]);
                                }
                            }
                        },
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: '#f0f0f0',
                                borderDash: [5, 5]
                            },
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }
    </script>
}