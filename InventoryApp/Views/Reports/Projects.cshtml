@model List<InventoryApp.Models.Project>

@{
    ViewData["Title"] = "Report projektů";
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <style>
        .card {
            border: none;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }

        #reportTable thead th {
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 700;
            color: #212529;
            background-color: #fff;
            border-bottom: 1px solid #dee2e6;
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        #reportTable tbody td {
            vertical-align: middle;
            padding-top: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #f2f2f2;
        }

        #reportTable tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }

        .dataTables_wrapper .row:first-child {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #f0f0f0;
            background-color: #fff;
            margin-bottom: 0;
            align-items: center;
        }

        .dataTables_wrapper .row:last-child {
            padding: 1rem 1.5rem;
            border-top: 1px solid #f0f0f0;
            background-color: #fff;
            margin-top: 0;
            align-items: center;
        }

        .dataTables_length select {
            border-radius: 0.375rem;
            border: 1px solid #dee2e6;
            padding: 0.375rem 2.25rem 0.375rem 0.75rem;
            margin: 0 0.5rem;
        }

        .dataTables_filter input {
            border-radius: 0.375rem;
            border: 1px solid #dee2e6;
            padding: 0.375rem 0.75rem;
            margin-left: 0.5rem;
        }

        .dataTables_length label, .dataTables_filter label {
            font-size: 0.875rem;
            color: #6c757d;
            font-weight: 500;
        }

        .page-link {
            color: #6c757d;
            border-radius: 0.375rem;
            margin: 0 3px;
            font-weight: 500;
            font-size: 0.875rem;
            border: none;
        }

            .page-link:hover {
                background-color: #f8f9fa;
                color: #0d6efd;
            }

        .page-item.active .page-link {
            background-color: #0d6efd;
            color: #fff;
            box-shadow: 0 2px 5px rgba(13, 110, 253, 0.3);
        }

        .page-item.disabled .page-link {
            background-color: transparent;
            color: #adb5bd;
        }

        .dataTables_info {
            font-size: 0.875rem;
            color: #6c757d !important;
            padding-top: 0 !important;
        }

        .nav-pills .nav-link.active {
            background-color: #0d6efd;
            color: white;
            font-weight: 600;
        }

        .nav-pills .nav-link {
            color: #495057;
            background-color: #fff;
            border: 1px solid #dee2e6;
            margin-right: 0.5rem;
        }

        .icon-box {
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.5rem;
        }
    </style>
}

<div class="container-fluid" style="max-width: 1400px; padding-top: 1rem;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Reporty</h2>
            <p class="text-muted mb-0">Analýza zásob a projektů</p>
        </div>
        <ul class="nav nav-pills">
            <li class="nav-item">
                <a class="nav-link @(action == "LowStock" ? "active shadow-sm" : "")" asp-controller="Reports" asp-action="LowStock"><i class="bi bi-exclamation-triangle me-1"></i> Dochází</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(action == "Consumption" ? "active shadow-sm" : "")" asp-controller="Reports" asp-action="Consumption"><i class="bi bi-graph-down me-1"></i> Spotřeba</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(action == "Projects" ? "active shadow-sm" : "")" asp-controller="Reports" asp-action="Projects"><i class="bi bi-clipboard2-check me-1"></i> Projekty</a>
            </li>
        </ul>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
            <div class="mb-3 text-muted opacity-25"><i class="bi bi-kanban" style="font-size: 3rem;"></i></div>
            <h5 class="fw-bold">Žádné projekty</h5>
            <p class="text-muted">V systému se zatím nenachází žádné projekty k analýze.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="reportTable" class="table table-hover align-middle mb-0" style="width:100%">
                        <thead>
                            <tr>
                                <th class="ps-4">Projekt</th>
                                <th class="text-center">Stav</th>
                                <th class="text-center">Kusovník (Materiál)</th>
                                <th class="text-center">Odhad (h)</th>
                                <th class="text-center">Realita (h)</th>
                                <th class="text-end pe-4">Akce</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                string badgeClass = r.Status switch
                                {
                                    InventoryApp.Models.ProjectStatus.Planning => "bg-secondary",
                                    InventoryApp.Models.ProjectStatus.Ordered => "bg-warning text-dark",
                                    InventoryApp.Models.ProjectStatus.ReadyToBuild => "bg-info text-dark",
                                    InventoryApp.Models.ProjectStatus.InProduction => "bg-primary",
                                    InventoryApp.Models.ProjectStatus.Completed => "bg-success",
                                    _ => "bg-light text-dark border"
                                };

                                string statusText = r.Status switch
                                {
                                    InventoryApp.Models.ProjectStatus.Planning => "Plánování",
                                    InventoryApp.Models.ProjectStatus.Ordered => "Objednáno",
                                    InventoryApp.Models.ProjectStatus.ReadyToBuild => "Připraveno",
                                    InventoryApp.Models.ProjectStatus.InProduction => "Ve výrobě",
                                    InventoryApp.Models.ProjectStatus.Completed => "Hotovo",
                                    _ => r.Status.ToString()
                                };

                                int totalItems = r.Items?.Count ?? 0;

                                <tr style="cursor: pointer;" onclick="window.location='@Url.Action("Details", "Projects", new { id = r.Id })'">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="icon-box bg-dark bg-opacity-10 text-dark me-3 flex-shrink-0">
                                                <i class="bi bi-journal-code fs-5"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@r.Name</div>
                                                <small class="text-muted">Vytvořeno: @r.CreatedAt.ToString("d. M. yyyy")</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @switch (r.Status)
                                        {
                                            case InventoryApp.Models.ProjectStatus.Planning:
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill px-3 py-2"><i class="bi bi-lightbulb me-1"></i> Plánování</span>
                                                break;
                                            case InventoryApp.Models.ProjectStatus.Ordered:
                                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3 py-2"><i class="bi bi-cart me-1"></i> Objednáno</span>
                                                break;
                                            case InventoryApp.Models.ProjectStatus.ReadyToBuild:
                                                <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-3 py-2"><i class="bi bi-box-seam me-1"></i> Připraveno</span>
                                                break;
                                            case InventoryApp.Models.ProjectStatus.InProduction:
                                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary rounded-pill px-3 py-2"><i class="bi bi-tools me-1"></i> Ve výrobě</span>
                                                break;
                                            case InventoryApp.Models.ProjectStatus.Completed:
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2"><i class="bi bi-check-circle me-1"></i> Hotovo</span>
                                                break;
                                            default:
                                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">@r.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold text-dark fs-6">@totalItems</span> <small class="text-muted">dílů</small>
                                    </td>
                                    <td class="text-center text-muted">@r.EstimatedHours</td>
                                    <td class="text-center fw-bold @(r.RealHours > r.EstimatedHours ? "text-danger" : "text-success")">
                                        @r.RealHours
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn btn-sm btn-light border shadow-sm rounded-circle" style="width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-chevron-right text-muted"></i>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#reportTable').DataTable({
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.4/i18n/cs.json",
                    searchPlaceholder: "Hledat projekt..."
                },
                columnDefs: [ { orderable: false, targets: 5 } ],
                order: [],
                pageLength: 25,
                stateSave: true,
                dom: "<'row'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>"
            });
        });
    </script>
}
