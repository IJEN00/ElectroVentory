@model InventoryApp.ViewModels.ProjectDetailViewModel
@using InventoryApp.Models

@{
    ViewData["Title"] = $"Projekt: {Model.Project.Name}";
    bool isLocked = Model.Project.ConsumedAt != null;
}

<div class="container-fluid" style="max-width: 1400px;">

    @* --- HLAVIČKA A STAVY PROJEKTU --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">

        @* LEVÁ STRANA: Nadpis a stavy *@
        <div>
            <div class="d-flex align-items-center gap-3">
                <h2 class="fw-bold mb-0">@Model.Project.Name</h2>

                @switch (Model.Project.Status)
                {
                    case ProjectStatus.Planning:
                        <span class="badge bg-secondary rounded-pill">Plánování</span>
                        break;
                    case ProjectStatus.Ordered:
                        <span class="badge bg-warning text-dark rounded-pill">Objednáno</span>
                        break;
                    case ProjectStatus.ReadyToBuild:
                        <span class="badge bg-info text-dark rounded-pill">Připraveno</span>
                        break;
                    case ProjectStatus.InProduction:
                        <span class="badge bg-primary rounded-pill">Ve výrobě</span>
                        break;
                    case ProjectStatus.Completed:
                        <span class="badge bg-success rounded-pill">Hotovo</span>
                        break;
                    default:
                        <span class="badge bg-light text-dark border">@Model.Project.Status</span>
                        break;
                }
            </div>

            <div class="text-muted small mt-1 d-flex gap-3">
                <span><i class="bi bi-clock me-1"></i> Odhad: <strong>@Model.Project.EstimatedHours h</strong></span>
                <span><i class="bi bi-stopwatch me-1"></i> Realita: <strong>@Model.Project.RealHours h</strong></span>
                <span class="d-none d-md-inline">| Vytvořeno: @Model.Project.CreatedAt.ToLocalTime().ToString("d. M. yyyy")</span>
            </div>
        </div>

        @* PRAVÁ STRANA: Tlačítka *@
        <div class="d-flex gap-2">

            <a asp-action="Index" class="btn btn-light border text-secondary shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Zpět
            </a>

            @if (!isLocked)
            {
                <a asp-action="Edit" asp-route-id="@Model.Project.Id" class="btn btn-light border text-secondary shadow-sm" title="Upravit nastavení">
                    <i class="bi bi-pencil me-1"></i> <span class="d-none d-lg-inline">Upravit</span>
                </a>

                <form asp-action="ConsumeFromStock" method="post" onsubmit="return confirm('Opravdu odečíst položky ze skladu? Projekt se uzamkne.');">
                    <input type="hidden" name="id" value="@Model.Project.Id" />
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-box-seam me-2"></i>Vyskladnit
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-light border text-secondary shadow-sm opacity-50" disabled>
                    <i class="bi bi-pencil me-1"></i> <span class="d-none d-lg-inline">Upravit</span>
                </button>

                <button class="btn btn-secondary shadow-sm" disabled>
                    <i class="bi bi-lock-fill me-2"></i>Uzamčeno
                </button>
            }
        </div>
    </div>

    <div class="text-muted description-content mb-4 mt-2 ps-3 border-start border-3">
        @Model.Project.Description
    </div>

    @* --- DASHBOARD KARTY --- *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Stav kompletace</h6>
                    <div class="d-flex align-items-baseline gap-2">
                        <h3 class="mb-0">@Model.Progress%</h3>
                        <span class="text-muted small">hotovo</span>
                    </div>
                    <div class="progress mt-2" style="height: 6px;">
                        <div class="progress-bar @Model.ProgressColor" role="progressbar" style="width: @Model.Progress%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Položky</h6>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-0">@Model.TotalItems</h3>
                            <small class="text-muted">unikátních dílů</small>
                        </div>
                        <div class="icon-shape bg-light text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-list-task fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm @(Model.TotalToBuy > 0 ? "border-start border-4 border-warning" : "border-start border-4 border-success")">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Chybí k nákupu</h6>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-0 @(Model.TotalToBuy > 0 ? "text-warning" : "text-success")">@Model.TotalToBuy <span class="fs-6 text-muted">ks</span></h3>
                            <small class="text-muted">nutno objednat</small>
                        </div>
                        <div class="icon-shape bg-light text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-cart fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold">Sklad</h6>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-0">@Model.TotalFromStock</h3>
                            <small class="text-muted">ks rezervováno</small>
                        </div>
                        <div class="icon-shape bg-light text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-box2 fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger shadow-sm border-0 border-start border-4 border-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
        </div>
    }

    @* --- HLAVNÍ OBSAH (TABS) --- *@
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom-0 pt-3 px-4">
            <ul class="nav nav-tabs card-header-tabs" id="projectTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold" id="bom-tab" data-bs-toggle="tab" data-bs-target="#bom" type="button" role="tab">
                        <i class="bi bi-list-task me-1"></i> Kusovník (BOM)
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold position-relative" id="buy-tab" data-bs-toggle="tab" data-bs-target="#buy" type="button" role="tab">
                        <i class="bi bi-currency-dollar me-1"></i> Nákup a Ceny
                        @if (Model.TotalToBuy > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6em">@Model.TotalToBuy</span>
                        }
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" id="order-tab" data-bs-toggle="tab" data-bs-target="#order" type="button" role="tab">
                        <i class="bi bi-receipt me-1"></i> Objednávka
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" id="files-tab" data-bs-toggle="tab" data-bs-target="#files" type="button" role="tab">
                        <i class="bi bi-paperclip me-1"></i> Přílohy
                        @if (Model.Project.Documents != null && Model.Project.Documents.Any())
                        {
                            <span class="badge bg-secondary rounded-pill ms-1">@Model.Project.Documents.Count</span>
                        }
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-0">
            <div class="tab-content" id="projectTabsContent">

                @* --- TAB 1: KUSOVNÍK (BOM) --- *@
                <div class="tab-pane fade show active" id="bom" role="tabpanel">
                    <div class="p-4">

                        <div class="card border rounded-4 shadow-sm mb-4">
                            <div class="card-body p-0 table-responsive">
                                <table class="table table-hover align-middle mb-0" style="min-width: 800px;">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 text-center text-secondary text-uppercase py-3 border-bottom-0" style="width: 60px; font-size: 0.85rem;">Typ</th>
                                            <th class="text-secondary text-uppercase py-3 border-bottom-0" style="font-size: 0.85rem;">Položka</th>
                                            <th class="text-center text-secondary text-uppercase py-3 border-bottom-0" style="font-size: 0.85rem;">Potřeba</th>
                                            <th class="text-center text-secondary text-uppercase py-3 border-bottom-0" style="font-size: 0.85rem;">Skladem</th>
                                            <th class="text-center text-secondary text-uppercase py-3 border-bottom-0" style="font-size: 0.85rem;">Chybí</th>
                                            <th class="text-end pe-4 text-secondary text-uppercase py-3 border-bottom-0" style="font-size: 0.85rem;">Akce</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Project.Items != null && Model.Project.Items.Any())
                                        {
                                            foreach (var item in Model.Project.Items.OrderBy(i => i.Type).ThenBy(i => i.Id))
                                            {
                                                string name = item.Component?.Name ?? item.CustomName ?? "Unknown";
                                                string manu = item.Component?.Manufacturer ?? "-";
                                                string mpn = item.Component?.ManufacturerPartNumber ?? "-";

                                                <tr>
                                                    <td class="ps-4 text-center fs-5 text-muted border-bottom">
                                                        @if (item.Type == ProjectItemType.PCB)
                                                        {
                                                            <i class="bi bi-motherboard" title="PCB Deska" data-bs-toggle="tooltip"></i>
                                                        }
                                                        else if (item.Type == ProjectItemType.Print3D)
                                                        {
                                                            <i class="bi bi-box-seam" title="3D Tisk" data-bs-toggle="tooltip"></i>
                                                        }
                                                        else if (item.Type == ProjectItemType.Other)
                                                        {
                                                            <i class="bi bi-tools" title="Jiné" data-bs-toggle="tooltip"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-cpu" title="Součástka" data-bs-toggle="tooltip"></i>
                                                        }
                                                    </td>

                                                    <td class="border-bottom">
                                                        @if (item.Type == ProjectItemType.Standard && item.ComponentId != null)
                                                        {
                                                            <a asp-controller="Components" asp-action="Details" asp-route-id="@item.ComponentId" class="fw-bold text-decoration-none" title="Přejít na detail součástky">
                                                                @name
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <div class="fw-bold text-dark">@name</div>
                                                        }

                                                        @if (item.Type == ProjectItemType.Standard)
                                                        {
                                                            <div class="small text-muted mt-1">@manu | @mpn</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="small text-muted fst-italic mt-1">Vlastní výroba / Externí</div>
                                                        }
                                                    </td>

                                                    <td class="text-center fs-5 fw-bold border-bottom">@item.QuantityRequired</td>

                                                    <td class="text-center border-bottom">
                                                        @if (item.Type == ProjectItemType.Standard)
                                                        {
                                                            @if (item.QuantityFromStock > 0)
                                                            {
                                                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                                                                    <i class="bi bi-check2"></i> @item.QuantityFromStock
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted small fw-bold">-</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            @if (item.IsFulfilled)
                                                            {
                                                                <form asp-action="ToggleFulfillment" method="post" class="d-inline">
                                                                    <input type="hidden" name="itemId" value="@item.Id" />
                                                                    <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                                                    <button type="submit" class="btn badge bg-success text-white border-0 rounded-pill px-3 py-2" title="Kliknutím zrušit">
                                                                        <i class="bi bi-check-lg me-1"></i> Hotovo
                                                                    </button>
                                                                </form>
                                                            }
                                                            else
                                                            {
                                                                <form asp-action="ToggleFulfillment" method="post" class="d-inline">
                                                                    <input type="hidden" name="itemId" value="@item.Id" />
                                                                    <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                                                    <button type="submit" class="btn badge bg-light text-secondary border rounded-pill px-3 py-2" title="Označit jako hotové/doručené">
                                                                        <i class="bi bi-circle me-1"></i> Čekám
                                                                    </button>
                                                                </form>
                                                            }
                                                        }
                                                    </td>

                                                    <td class="text-center border-bottom">
                                                        @if (item.QuantityToBuy > 0 && !item.IsFulfilled)
                                                        {
                                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3 py-2">
                                                                <i class="bi bi-exclamation-circle me-1"></i> @item.QuantityToBuy
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small"><i class="bi bi-check-all me-1"></i> OK</span>
                                                        }
                                                    </td>

                                                    <td class="text-end pe-4 border-bottom">
                                                        @if (!Model.IsLocked)
                                                        {
                                                            <form asp-action="DeleteItem" method="post" class="d-inline">
                                                                <input type="hidden" name="id" value="@item.Id" />
                                                                <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0 opacity-75 custom-hover-opacity" title="Odstranit">
                                                                    <i class="bi bi-trash fs-5"></i>
                                                                </button>
                                                            </form>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="6" class="text-center py-5 text-muted border-bottom-0">
                                                    <i class="bi bi-box-seam fs-1 d-block mb-3 opacity-50"></i>
                                                    Kusovník je zatím prázdný.<br>
                                                    <small>Přidejte součástky nebo desky pomocí formuláře níže.</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>                   

                        @* --- PŘIDAT POLOŽKU --- *@
                        @if (!Model.IsLocked)
                        {
                            <div class="card bg-light border-0 rounded-4 shadow-sm p-4 mt-4 mb-2">
                                <h6 class="fw-bold mb-3 text-secondary text-uppercase" style="font-size: 0.85rem;">
                                    <i class="bi bi-plus-circle me-2"></i>Přidat položku do kusovníku
                                </h6>

                                <form asp-action="AddItem" method="post" class="row g-3 align-items-end">
                                    <input type="hidden" name="projectId" value="@Model.Project.Id" />

                                    <div class="col-md-3">
                                        <label class="form-label small text-muted fw-bold mb-1">Typ položky</label>
                                        <select name="type" class="form-select border-0 shadow-sm" id="itemTypeSelect">
                                            <option value="Standard">Součástka ze skladu</option>
                                            <option value="PCB">Plošný spoj (PCB)</option>
                                            <option value="Print3D">3D Tisk</option>
                                            <option value="Other">Jiné (Externí)</option>
                                        </select>
                                    </div>

                                    <div class="col-md-5" id="componentSelectGroup">
                                        <label class="form-label small text-muted fw-bold mb-1">Vyhledat součástku</label>
                                        <select asp-for="SelectedComponentId" asp-items="Model.AvailableComponents" id="componentSelect" class="form-select border-0 shadow-sm">
                                        </select>
                                    </div>

                                    <div class="col-md-5" id="customNameGroup" style="display:none;">
                                        <label class="form-label small text-muted fw-bold mb-1">Vlastní název</label>
                                        <input asp-for="CustomName" class="form-control border-0 shadow-sm" placeholder="Např. Krabička víko v2..." />
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label small text-muted fw-bold mb-1">Potřeba ks</label>
                                        <input asp-for="QuantityRequired" class="form-control border-0 shadow-sm text-center" min="1" value="1" />
                                    </div>

                                    <div class="col-md-2">
                                        <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm"><i class="bi bi-plus-lg me-1"></i> Přidat</button>
                                    </div>
                                </form>
                            </div>
                        }
                    </div>
                </div>

                @* --- TAB 2: NÁKUP --- *@
                <div class="tab-pane fade" id="buy" role="tabpanel">
                    <div class="p-4">
                        @{
                            var itemsToBuy = Model.Project.Items?
                            .Where(i => !i.IsFulfilled && i.QuantityToBuy > 0 && (i.Type == ProjectItemType.Standard || i.Type == ProjectItemType.Other))
                            .ToList() ?? new List<ProjectItem>();

                            bool anyOffers = itemsToBuy.Any(i => i.SupplierOffers != null && i.SupplierOffers.Any());
                        }

                        @if (itemsToBuy.Any())
                        {
                            @if (!Model.IsLocked)
                            {
                                <div class="d-flex gap-2 mb-4">
                                    <form asp-action="FindOffers" method="post" id="findOffersForm">
                                        <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                        <button type="submit" id="loadPricesBtn" class="btn btn-outline-primary rounded-pill px-4" onclick="showLoadingState()">
                                            @if (anyOffers)
                                            {
                                                <i id="loadPricesIcon" class="bi bi-arrow-repeat me-2"></i>
                                                <span id="loadPricesText">Aktualizovat</span>
                                            }
                                            else
                                            {
                                                <i id="loadPricesIcon" class="bi bi-search me-2"></i>
                                                <span id="loadPricesText">Načíst ceny</span>
                                            }
                                        </button>
                                    </form>

                                    <form asp-action="AutoSelectCheapest" method="post">
                                        <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                        <button type="submit" class="btn btn-outline-secondary rounded-pill px-4" @(!anyOffers ? "disabled" : "")>
                                            <i class="bi bi-magic me-2"></i> Vybrat nejlevnější
                                        </button>
                                    </form>
                                </div>
                            }

                            @if (anyOffers)
                            {
                                <div class="card border rounded-4 shadow-sm mb-4">
                                    <div class="card-body p-0 table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th class="ps-4 py-3 border-bottom-0 text-secondary text-uppercase" style="font-size: 0.85rem;">Součástka</th>
                                                    <th class="py-3 border-bottom-0 text-secondary text-uppercase" style="font-size: 0.85rem;">Dodavatel</th>
                                                    <th class="py-3 border-bottom-0 text-secondary text-uppercase" style="font-size: 0.85rem;">Cena / Ks</th>
                                                    <th class="pe-4 py-3 border-bottom-0 text-secondary text-end text-uppercase" style="font-size: 0.85rem;">Akce</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in itemsToBuy)
                                                {
                                                    string name = item.Component?.Name ?? item.CustomName ?? "Unknown";
                                                    var offers = item.SupplierOffers?.OrderBy(o => o.UnitPrice).ToList() ?? new List<SupplierOffer>();

                                                    if (offers.Any())
                                                    {
                                                        for (int i = 0; i < offers.Count; i++)
                                                        {
                                                            var offer = offers[i];
                                                            var rowClass = offer.IsSelected ? "bg-success bg-opacity-10" : "";

                                                            <tr class="@rowClass">
                                                                @if (i == 0)
                                                                {
                                                                    <td class="ps-4 border-bottom" rowspan="@offers.Count">
                                                                        <strong class="text-dark">@name</strong>
                                                                        <span class="badge bg-secondary ms-2">@item.QuantityToBuy ks</span>
                                                                    </td>
                                                                }

                                                                <td class="border-bottom">
                                                                    @if (!string.IsNullOrEmpty(offer.ProductUrl))
                                                                    {
                                                                        <a href="@offer.ProductUrl" target="_blank" class="fw-bold text-decoration-none" title="Otevřít produkt na webu dodavatele">
                                                                            @offer.Supplier?.Name
                                                                            <i class="bi bi-box-arrow-up-right small ms-1"></i>
                                                                        </a>
                                                                    }
                                                                    else
                                                                    {
                                                                        <strong class="text-dark">@offer.Supplier?.Name</strong>
                                                                    }
                                                                </td>

                                                                <td class="border-bottom">
                                                                    <span class="badge border border-success text-success bg-white px-3 py-2 fs-6 fw-normal">
                                                                        @offer.UnitPrice.ToString("N2") @offer.Currency
                                                                    </span>
                                                                </td>

                                                                <td class="text-end pe-4 border-bottom">
                                                                    @if (offer.IsSelected)
                                                                    {
                                                                        <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-check2 me-1"></i> Vybráno</span>
                                                                    }
                                                                    else if (!Model.IsLocked)
                                                                    {
                                                                        <form asp-action="SelectOffer" method="post" class="d-inline">
                                                                            <input type="hidden" name="offerId" value="@offer.Id" />
                                                                            <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                                                            <button class="btn btn-sm btn-outline-primary rounded-pill px-4">Vybrat</button>
                                                                        </form>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <tr>
                                                            <td class="ps-4 border-bottom">
                                                                <strong class="text-dark">@name</strong>
                                                                <span class="badge bg-secondary ms-2">@item.QuantityToBuy ks</span>
                                                            </td>
                                                            <td colspan="3" class="border-bottom py-3 text-muted fst-italic">
                                                                Žádné nabídky nalezeny.
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <small class="text-muted d-block text-end fst-italic mb-3">Ceny jsou orientační a mohou se změnit.</small>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="bi bi-search fs-1 text-muted d-block mb-3 opacity-50"></i>
                                    <h5 class="text-dark fw-bold">Zatím nebyly načteny ceny</h5>
                                    <p class="text-muted mt-2">Klikněte na tlačítko "Načíst ceny" pro vyhledání u dodavatelů.</p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-cart-check fs-1 d-block mb-3 opacity-50 text-success"></i>
                                <h5 class="text-dark fw-bold">Není co nakupovat</h5>
                                <p class="text-muted mb-4">Kusovník je prázdný, nebo máte všechny potřebné součástky aktuálně skladem.</p>

                                <button class="btn btn-outline-primary rounded-pill px-4 shadow-sm" onclick="var tab = new bootstrap.Tab(document.querySelector('#bom-tab')); tab.show();">
                                    <i class="bi bi-card-list me-2"></i> Přejít do Kusovníku
                                </button>
                            </div>
                        }
                    </div>
                </div>

                @* --- TAB 3: OBJEDNÁVKA --- *@
                <div class="tab-pane fade" id="order" role="tabpanel">
                    @{
                        var selectedOffers = Model.Project.Items?
                        .Where(i => !i.IsFulfilled && i.QuantityToBuy > 0)
                        .Where(i => i.SupplierOffers != null && i.SupplierOffers.Any(o => o.IsSelected))
                        .SelectMany(i => i.SupplierOffers
                        .Where(o => o.IsSelected)
                        .Select(o => new { Item = i, Offer = o }))
                        .GroupBy(x => x.Offer.Supplier?.Name ?? "Neznámý dodavatel")
                        .ToList();

                        decimal grandTotal = 0;
                        string mainCurrency = "CZK"; 
                    }

                    <div class="p-4">
                        @if (selectedOffers != null && selectedOffers.Any())
                        {
                            <h6 class="fw-bold mb-4 text-secondary text-uppercase" style="font-size: 0.85rem;">
                                <i class="bi bi-box-seam me-2"></i>Souhrn podle dodavatelů
                            </h6>

                            <div class="row g-4 mb-4">
                                @foreach (var supplierGroup in selectedOffers)
                                {
                                    decimal supplierTotal = supplierGroup.Sum(x => x.Item.QuantityToBuy * x.Offer.UnitPrice);
                                    string currency = supplierGroup.First().Offer.Currency;
                                    grandTotal += supplierTotal;

                                    <div class="col-md-6 col-lg-4">
                                        <div class="card border rounded-4 shadow-sm h-100 overflow-hidden">
                                            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 d-flex justify-content-between align-items-center">
                                                <span class="fw-bold text-dark fs-5">@supplierGroup.Key</span>
                                                <span class="badge border border-success text-success bg-white rounded-pill px-3 py-2 fs-6 fw-normal">
                                                    @supplierTotal.ToString("N2") @currency
                                                </span>
                                            </div>
                                            <div class="card-body p-0">
                                                <ul class="list-group list-group-flush small">
                                                    @foreach (var line in supplierGroup)
                                                    {
                                                        <li class="list-group-item d-flex justify-content-between align-items-center border-light px-4 py-3">
                                                            <div class="text-muted text-truncate me-3">
                                                                <span class="badge bg-secondary rounded-pill me-2">@line.Item.QuantityToBuy ks</span>
                                                                @(line.Item.Component?.Name ?? line.Item.CustomName ?? "Neznámá položka")
                                                            </div>
                                                            <span class="fw-bold text-dark">@((line.Item.QuantityToBuy * line.Offer.UnitPrice).ToString("N2"))</span>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="card bg-success bg-opacity-10 border-0 rounded-4 shadow-sm p-4 mt-2">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                                    <div>
                                        <h4 class="mb-1 fw-bold text-success">Celkem: @grandTotal.ToString("N2") @mainCurrency</h4>
                                        <small class="text-success text-opacity-75"><i class="bi bi-info-circle me-1"></i> Cena je orientační bez dopravy a poplatků</small>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2">
                                        @* --- PDF DROPDOWN --- *@
                                        <div class="dropdown">
                                            <button class="btn btn-dark rounded-pill px-4 shadow-sm fw-bold dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-file-pdf me-2"></i> Stáhnout PDF
                                            </button>
                                            <ul class="dropdown-menu shadow border-0 rounded-3 mt-2">
                                                <li class="dropdown-header text-muted fw-bold">Vyberte dodavatele:</li>
                                                @foreach (var supplierGroup in selectedOffers)
                                                {
                                                    <li>
                                                        <a class="dropdown-item py-2 d-flex align-items-center" asp-action="ExportSupplierPdf" asp-route-projectId="@Model.Project.Id" asp-route-supplierName="@supplierGroup.Key">
                                                            <i class="bi bi-download me-2 text-dark opacity-75"></i> Objednávka @supplierGroup.Key
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>

                                        @* --- CSV DROPDOWN --- *@
                                        <div class="dropdown">
                                            <button class="btn btn-success rounded-pill px-4 shadow-sm fw-bold dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-file-earmark-spreadsheet me-2"></i> Stáhnout CSV
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2">
                                                <li class="dropdown-header text-muted fw-bold">Vyberte dodavatele:</li>
                                                @foreach (var supplierGroup in selectedOffers)
                                                {
                                                    <li>
                                                        <a class="dropdown-item py-2 d-flex align-items-center" asp-action="ExportOrderCsv" asp-route-projectId="@Model.Project.Id" asp-route-supplierName="@supplierGroup.Key">
                                                            <i class="bi bi-download me-2 text-success opacity-75"></i> Pouze @supplierGroup.Key
                                                        </a>
                                                    </li>
                                                }
                                                <li><hr class="dropdown-divider opacity-25"></li>
                                                <li>
                                                    <a class="dropdown-item py-2 fw-bold d-flex align-items-center" asp-action="ExportOrderCsv" asp-route-projectId="@Model.Project.Id">
                                                        <i class="bi bi-files me-2 text-success"></i> Všichni dodavatelé
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-cart-x fs-1 d-block mb-3 opacity-50 text-muted"></i>
                                <h5 class="text-dark fw-bold">Zatím žádné vybrané nabídky</h5>
                                <p class="text-muted mb-4">Jděte na záložku "Nákup a Ceny", načtěte ceny a vyberte dodavatele.</p>

                                @if (Model.TotalToBuy > 0)
                                {
                                    <button class="btn btn-outline-primary rounded-pill px-4" onclick="var tab = new bootstrap.Tab(document.querySelector('#buy-tab')); tab.show();">
                                        <i class="bi bi-arrow-left me-2"></i> Přejít na výběr cen
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
                @* --- TAB 4: SOUBORY --- *@
                <div class="tab-pane fade" id="files" role="tabpanel">
                    <div class="p-4">

                        @if (Model.Project.Documents != null && Model.Project.Documents.Any())
                        {
                            <div class="row g-4">
                                @foreach (var doc in Model.Project.Documents.OrderByDescending(d => d.UploadedAt))
                                {
                                    <div class="col-md-4 col-lg-3">
                                        <div class="card h-100 border-0 shadow-sm rounded-4 file-card-hover">
                                            <div class="card-body text-center pt-4 pb-2">

                                                @if (doc.FileName.EndsWith(".pdf"))
                                                {
                                                    <div class="d-inline-block bg-danger bg-opacity-10 text-danger rounded-circle p-3 mb-3">
                                                        <i class="bi bi-file-pdf fs-1 d-block" style="line-height: 1;"></i>
                                                    </div>
                                                }
                                                else if (doc.FileName.EndsWith(".zip"))
                                                {
                                                    <div class="d-inline-block bg-warning bg-opacity-10 text-warning rounded-circle p-3 mb-3">
                                                        <i class="bi bi-file-zip fs-1 d-block" style="line-height: 1;"></i>
                                                    </div>
                                                }
                                                else if (doc.FileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
                                                doc.FileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                                                doc.FileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
                                                doc.FileName.EndsWith(".webp", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <a href="@doc.FilePath" target="_blank" class="d-block mb-3" title="Otevřít obrázek v plné velikosti">
                                                        <div class="d-flex justify-content-center align-items-center bg-white rounded-4 overflow-hidden mx-auto border shadow-sm" style="height: 80px; width: 80px; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                                                            <img src="@doc.FilePath" alt="Náhled" class="img-fluid" style="height: 100%; width: 100%; object-fit: cover;">
                                                        </div>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <div class="d-inline-block bg-primary bg-opacity-10 text-primary rounded-circle p-3 mb-3">
                                                        <i class="bi bi-file-earmark fs-1 d-block" style="line-height: 1;"></i>
                                                    </div>
                                                }

                                                <h6 class="card-title text-truncate fw-bold text-dark mb-1" title="@doc.FileName">@doc.FileName</h6>
                                                <small class="text-muted">@doc.UploadedAt.ToLocalTime().ToString("d. M. yyyy, HH:mm")</small>
                                            </div>

                                            <div class="card-footer bg-transparent border-top-0 d-flex justify-content-center gap-2 pb-4">
                                                <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-light text-primary rounded-pill px-3 shadow-sm fw-bold" title="Stáhnout">
                                                    <i class="bi bi-download me-1"></i> Stáhnout
                                                </a>
                                                @if (!Model.IsLocked)
                                                {
                                                    <form asp-action="DeleteFile" method="post" onsubmit="return confirm('Smazat soubor?');">
                                                        <input type="hidden" name="fileId" value="@doc.Id" />
                                                        <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm" title="Smazat">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-folder2-open fs-1 d-block mb-3 opacity-50"></i>
                                <h5 class="text-dark fw-bold">Žádné přílohy</h5>
                                <p class="mt-2">Nahrajte schémata, Gerber data nebo datasheety pomocí formuláře níže.</p>
                            </div>
                        }

                        @* --- NAHRÁNÍ SOUBORŮ --- *@
                        @if (!Model.IsLocked)
                        {
                            <div class="card bg-light border-0 rounded-4 shadow-sm p-4 mt-4 mb-2">
                                <h6 class="fw-bold mb-3 text-secondary text-uppercase" style="font-size: 0.85rem;">
                                    <i class="bi bi-cloud-upload me-2"></i>Nahrát nové soubory
                                </h6>

                                <form asp-action="UploadFiles" method="post" enctype="multipart/form-data" class="row g-3 align-items-end">
                                    <input type="hidden" name="id" value="@Model.Project.Id" />

                                    <div class="col-md-9">
                                        <label class="form-label small text-muted fw-bold mb-1">Vyberte soubory (PDF, ZIP, Obrázky...)</label>
                                        <input type="file" name="files" class="form-control border-0 shadow-sm" multiple />
                                    </div>

                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm">
                                            <i class="bi bi-upload me-1"></i> Nahrát do projektu
                                        </button>
                                    </div>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .select2-container--bootstrap-5 .select2-selection {
            border: 1px solid #dee2e6;
            border-radius: 0.375rem;
            min-height: 38px;
            padding-top: 4px;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    <script>
        $(function () {
            $('#componentSelect').select2({
                theme: 'bootstrap-5',
                width: '100%',
                placeholder: 'Vyber součástku ze skladu...',
                allowClear: true
            });

            var descEl = document.querySelector('.description-content');
            if (descEl) {
                var raw = descEl.innerText;
                if (raw && raw.trim().length > 0) {
                    descEl.innerHTML = marked.parse(raw);
                } else {
                    descEl.innerHTML = '<span class="fst-italic small">Bez popisu</span>';
                }
            }

            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })

            $('#itemTypeSelect').change(function() {
                var val = $(this).val();
                if (val === 'Standard') {
                    $('#componentSelectGroup').show();
                    $('#customNameGroup').hide();
                } else {
                    $('#componentSelectGroup').hide();
                    $('#customNameGroup').show();
                    $('#componentSelect').val(null).trigger('change');
                }
            });

            var activeTab = localStorage.getItem('activeProjectTab');
            if (activeTab) {
                var tabTrigger = document.querySelector(`button[data-bs-target="${activeTab}"]`);
                if (tabTrigger) {
                    var tab = new bootstrap.Tab(tabTrigger);
                    tab.show();
                }
            }
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                var targetId = $(e.target).attr('data-bs-target');
                localStorage.setItem('activeProjectTab', targetId);
            });
        });

        function showLoadingState() {
        const btn = document.getElementById('loadPricesBtn');
        const icon = document.getElementById('loadPricesIcon');
        const text = document.getElementById('loadPricesText');

        icon.className = 'spinner-border spinner-border-sm me-2';
        icon.setAttribute('role', 'status');
        icon.setAttribute('aria-hidden', 'true');

        text.innerText = 'Hledám...';

        setTimeout(() => {
            btn.classList.add('disabled');
        }, 10);
        }
    </script>
}